# ===========================================
# AI 职位雷达 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# DeepSeek（API Key 和 Base URL 两个模型共用）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# 深度匹配 Agent（应对 api 偶发断流 / incomplete chunked read）
# MATCH_AGENT_MODE=single
#   single（默认）：单次 Function Calling 提交 submit_match_result + 后置校验重试
#   loop：多轮工具循环（get_job_detail / verify_score 等），便于后续接 RAG
# MATCH_AGENT_POST_VALIDATE_MAX_RETRIES=2
#   后置校验失败时额外重试次数（不含首次），默认 2 → 最多 3 次 API 调用
# MATCH_AGENT_SINGLE_MAX_JD_CHARS=12000
#   单次模式 user 消息中 JD 全文最大长度
# MATCH_AGENT_HTTP_READ_TIMEOUT=420
# MATCH_AGENT_HTTP_CONNECT_TIMEOUT=60
# MATCH_AGENT_COMPLETION_RETRIES=6
# MATCH_AGENT_OPENAI_SDK_MAX_RETRIES=0
# 深度匹配每轮对话（模型+工具）之后、下一轮请求前的间隔（秒），仅 loop 模式；减轻 API 过密导致断流
# MATCH_AGENT_ROUND_DELAY_SEC=1.0
# 发往 LLM 时保留最近 N 条 tool 全文，更早的压缩为摘要（仅 loop 模式）
# MATCH_AGENT_TOOL_COMPRESS_KEEP_LAST=8
# MATCH_AGENT_TOOL_COMPRESS_PREVIEW=480
# 每次「开始匹配」时，对历史记录中 ≥80（HEAVY_THRESHOLD）且缺深度的岗位补跑深度匹配，单次最多处理条数
# MATCH_DEEP_BACKFILL_MAX=50
